{
  "name": "openclaw-pairing",
  "version": "1.0.0",
  "description": "Cross-platform device pairing plugin for OpenClaw (Android/HarmonyOS/iOS)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest --passWithNoTests || true",
    "test:watch": "jest --watch",
    "lint": "echo 'No lint configured'"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "device-pairing",
    "android",
    "harmonyos",
    "ios"
  ],
  "author": "feiclaw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/feiclaw/openclaw-pairing.git"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "openclawPlugin": {
    "name": "device-pairing",
    "version": "1.0.0",
    "commands": [
      "pair-android",
      "pair-harmony",
      "pair-ios",
      "pair-auto"
    ]
  }
}
